{
  "name": "ifol-render-sdk",
  "version": "0.3.0",
  "description": "GPU-accelerated 2D rendering SDK for web. Unit coordinate system, multi-viewport, resolution scaling.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build:wasm": "cd ../crates/wasm && wasm-pack build --target web --release",
    "build:ts": "tsc",
    "build": "npm run build:ts",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "test": "node --test dist/tests/"
  },
  "dependencies": {
    "ifol-render-wasm": "file:../crates/wasm/pkg"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "keywords": ["rendering", "webgpu", "wasm", "2d", "video-editor", "gpu"],
  "license": "MIT"
}
